generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  reader
  writer
  editor
  publisher
  admin
}

enum UserStatus {
  active
  suspended
  disabled
}

enum RoleRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum AuditAction {
  register
  login
  logout
  password_changed
  password_reset_requested
  email_verified
  profile_updated
  role_requested
  role_request_reviewed
  work_created
  work_published
  ownership_stamp_created
}

model User {
  id           String  @id @default(uuid()) @db.Char(36)
  email        String  @unique @db.VarChar(191)
  passwordHash String  @db.VarChar(255)
  fullName     String  @db.VarChar(160)
  displayName  String? @db.VarChar(160)
  username     String? @unique @db.VarChar(64)
  avatarUrl    String? @db.VarChar(500)
  bio          String? @db.Text

  role   UserRole   @default(reader)
  status UserStatus @default(active)

  emailVerified   DateTime?
  termsAcceptedAt DateTime?
  lastLoginAt     DateTime?
  isPremium       Boolean   @default(false)
  isBanned        Boolean   @default(false)
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile                 Profile?
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs                AuditLog[]   @relation("AuditLogActor")

  roleRequests         RoleRequest[] @relation("RoleRequestOwner")
  reviewedRoleRequests RoleRequest[] @relation("RoleRequestReviewer")

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([lastLoginAt])
  @@index([deletedAt])
}

model Profile {
  id     String @id @default(uuid()) @db.Char(36)
  userId String @unique @db.Char(36)

  website   String? @db.VarChar(500)
  instagram String? @db.VarChar(191)
  linkedin  String? @db.VarChar(500)
  twitter   String? @db.VarChar(191)

  country   String? @db.VarChar(100)
  city      String? @db.VarChar(100)
  birthYear Int?

  writingGenres       Json?
  completionPercentage Int @default(0) @db.UnsignedTinyInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country, city])
  @@index([completionPercentage])
}

model Session {
  id        String @id @default(uuid()) @db.Char(36)
  tokenHash String @unique @db.Char(64)
  userId    String @db.Char(36)

  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String @id @default(uuid()) @db.Char(36)
  tokenHash String @unique @db.Char(64)
  userId    String @db.Char(36)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String @id @default(uuid()) @db.Char(36)
  tokenHash String @unique @db.Char(64)
  userId    String @db.Char(36)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RoleRequest {
  id            String            @id @default(uuid()) @db.Char(36)
  userId        String            @db.Char(36)
  requestedRole UserRole
  status        RoleRequestStatus @default(pending)

  reviewedById String? @db.Char(36)
  reviewedAt   DateTime?
  reviewNote   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("RoleRequestOwner", fields: [userId], references: [id], onDelete: Cascade)

  reviewedBy User? @relation("RoleRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([requestedRole, status])
  @@index([reviewedById])
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(uuid()) @db.Char(36)
  actorId   String?     @db.Char(36)
  action    AuditAction
  entityType String?    @db.VarChar(80)
  entityId   String?    @db.VarChar(191)
  metadata   Json?
  ipAddress  String?    @db.VarChar(45)
  userAgent  String?    @db.VarChar(500)
  createdAt  DateTime    @default(now())

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}
